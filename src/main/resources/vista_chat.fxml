<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="600.0" prefWidth="450.0" stylesheets="@estilos.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.iesalandalus.ChatDAM.chat.cliente.ChatControlador">

    <top>
        <VBox>
            <MenuBar>
                <menus>
                    <Menu text="Opciones">
                        <items>
                            <MenuItem fx:id="menuSalir" onAction="#salirAplicacion" text="Salir de la aplicación" />
                        </items>
                    </Menu>
                </menus>
            </MenuBar>
            <HBox alignment="CENTER" prefHeight="50.0" styleClass="cabecera-chat">
                <Label styleClass="titulo-cabecera" text="Chat Corporativo AWS" />
            </HBox>
        </VBox>
    </top>

    <center>
        <ScrollPane fx:id="scrollMensajes" fitToWidth="true" styleClass="fondo-chat" BorderPane.alignment="CENTER">
            <content>
                <VBox fx:id="vboxMensajes" spacing="15.0" styleClass="fondo-chat">
                    <padding>
                        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                    </padding>
                </VBox>
            </content>
        </ScrollPane>
    </center>

    <bottom>
        <HBox alignment="CENTER" prefHeight="70.0" spacing="10.0" styleClass="barra-inferior" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="10.0" left="15.0" right="15.0" top="10.0" />
            </padding>
            <children>
                <TextField fx:id="txtInputMensaje" onAction="#enviarMensaje" prefHeight="45.0" promptText="Escribe un mensaje..." styleClass="campo-texto" HBox.hgrow="ALWAYS" />
                <Button fx:id="btnEnviar" mnemonicParsing="false" onAction="#enviarMensaje" prefHeight="45.0" prefWidth="90.0" styleClass="boton-enviar" text="Enviar" />
            </children>
        </HBox>
    </bottom>
</BorderPane>